# ----------------------------------------------------------------------------
# 1. Flutter / Dart 관련 (frontend/ 폴더 내부 파일 포함)
# ----------------------------------------------------------------------------
**/frontend/.dart_tool/
**/frontend/.flutter-plugins
**/frontend/.flutter-plugins-dependencies
**/frontend/.pub-cache/
**/frontend/build/
**/frontend/.packages
**/frontend/ios/.generated_files/

# ----------------------------------------------------------------------------
# 2. Python / Backend 관련
# ----------------------------------------------------------------------------
**/backend/**/__pycache__/
**/backend/__pycache__/
**/backend/**/*.py[cod]
**/backend/*.py[cod]
**/backend/.venv/
**/backend/venv/
**/backend/env/
**/backend/.env
**/backend/chroma_data/
**/backend/weights/

# ----------------------------------------------------------------------------
# 3. 운영체제 및 에디터 관련
# ----------------------------------------------------------------------------
.DS_Store
.vscode/
.idea/
*.swp
*.lock

# ----------------------------------------------------------------------------
# 4. 커스텀 설정 및 보안
# ----------------------------------------------------------------------------
